rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Bookings — any authenticated user can read (needed for slot availability checks)
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner"
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner"
      );
      allow delete: if false;
    }

    // Days off — owner can write, any authenticated user can read (needed for slot availability)
    match /daysOff/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner";
    }

    // Notifications — owner_inbox for shop alerts, {uid} for customer alerts
    match /notifications/{docId}/items/{itemId} {
      allow create: if request.auth != null && (
        docId == "owner_inbox" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner"
      );
      allow read, update: if request.auth != null && (
        (docId == "owner_inbox" &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner") ||
        docId == request.auth.uid
      );
    }
  }
}
